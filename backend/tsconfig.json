{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "middlewares/**/*", "routes/**/*", "utils/**/*", "prisma/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist"]
}
